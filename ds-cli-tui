#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.9"
# dependencies = ["PyYAML>=6,<7", "textual>=2,<3"]
# ///
"""ds-cli TUI launcher — runs the Textual-based list interface as a subprocess.

This is a separate entry point so that textual (a heavy dependency) is only
installed when the user actually opens the interactive list view via
`ds-cli list` on a terminal.  The main `ds-cli` script (run/resume/tail/
install/update) does not pull in textual at all.
"""

import sys
import os

# Ensure cli/ package is importable (same pattern as the main ds-cli script).
_ds_cli_dir = os.path.dirname(os.path.abspath(__file__))
if _ds_cli_dir not in sys.path:
    sys.path.insert(0, _ds_cli_dir)

from cli.config import Config
from cli.core import get_db
from cli.tui import RunListApp


def main():
    full_cwd = "--cwd" in sys.argv

    config = Config()
    conn = get_db()
    rows = conn.execute(
        "SELECT seq, run_id, uuid, cwd, prompt, created_at, jsonl_path, status, backend "
        "FROM runs ORDER BY created_at DESC LIMIT 50"
    ).fetchall()

    if not rows:
        conn.close()
        print("(no runs)")
        return

    def _refresh_rows():
        """Re-query the DB for the latest 50 runs.  Called by the TUI timer."""
        return conn.execute(
            "SELECT seq, run_id, uuid, cwd, prompt, created_at, jsonl_path, status, backend "
            "FROM runs ORDER BY created_at DESC LIMIT 50"
        ).fetchall()

    app = RunListApp(rows, full_cwd, refresh_fn=_refresh_rows)
    app.run(mouse=False)
    conn.close()

    # If the user pressed G (resume), handle it in this process so that
    # _resume_interactive's os.execvp replaces us — the tty is inherited from
    # the parent ds-cli process, so claude gets full terminal control.
    if app.action_result and app.action_result.startswith("resume:"):
        run_id = app.action_result[len("resume:"):]
        from cli.commands.resume import cmd_resume
        cmd_resume([run_id], config)


if __name__ == "__main__":
    main()
